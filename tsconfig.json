{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@postgresx/bun-listen": [
        "packages/bun-listen/src/index.ts"
      ],
      "@postgresx/noredis/adapters/ioredis": [
        "packages/pgredis/src/adapters/ioredis.ts"
      ],
      "@postgresx/noredis/adapters/redis": [
        "packages/pgredis/src/adapters/redis.ts"
      ]
    },
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "types": [
      "bun",
      "node"
    ]
  },
  "include": [
    "packages/*/src/**/*.ts",
    "benchmark/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
