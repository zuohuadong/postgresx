{
  "name": "@postgresx/noredis-ioredis",
  "version": "0.2.0",
  "description": "Thin ioredis-shaped facade package for @postgresx/noredis migrations",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist --external @postgresx/noredis",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@postgresx/noredis": "^0.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.0.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
