{
  "name": "@postgresx/noredis",
  "version": "0.3.0",
  "description": "PostgreSQL-backed Redis feature replacement toolkit: KV/TTL cache, pub/sub, advisory locks, rate limiting, and pg-boss queues",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters/bun": {
      "types": "./dist/adapters/bun.d.ts",
      "import": "./dist/adapters/bun.js",
      "default": "./dist/adapters/bun.js"
    },
    "./adapters/node": {
      "types": "./dist/adapters/node.d.ts",
      "import": "./dist/adapters/node.js",
      "default": "./dist/adapters/node.js"
    },
    "./adapters/web": {
      "types": "./dist/adapters/web.d.ts",
      "import": "./dist/adapters/web.js",
      "default": "./dist/adapters/web.js"
    },
    "./kv-cache": {
      "types": "./dist/kv-cache.d.ts",
      "import": "./dist/kv-cache.js",
      "default": "./dist/kv-cache.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/adapters/bun.ts src/adapters/node.ts src/adapters/web.ts src/kv-cache.ts --format esm --dts --clean --out-dir dist --external pg --external pg-boss --external @postgresx/bun-listen",
    "test": "bun test src",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.0.0",
    "@types/pg": "^8.16.0",
    "@postgresx/bun-listen": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
