{
  "name": "@postgresx/noredis",
  "version": "0.6.0",
  "description": "PostgreSQL-backed Redis feature replacement toolkit: KV/TTL cache, pub/sub, advisory locks, rate limiting, and pg-boss queues",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zuohuadong/postgresx",
    "directory": "packages/pgredis"
  },
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters/bun": {
      "types": "./dist/adapters/bun.d.ts",
      "import": "./dist/adapters/bun.js",
      "default": "./dist/adapters/bun.js"
    },
    "./adapters/node": {
      "types": "./dist/adapters/node.d.ts",
      "import": "./dist/adapters/node.js",
      "default": "./dist/adapters/node.js"
    },
    "./adapters/web": {
      "types": "./dist/adapters/web.d.ts",
      "import": "./dist/adapters/web.js",
      "default": "./dist/adapters/web.js"
    },
    "./adapters/ioredis": {
      "types": "./dist/adapters/ioredis.d.ts",
      "import": "./dist/adapters/ioredis.js",
      "default": "./dist/adapters/ioredis.js"
    },
    "./adapters/redis": {
      "types": "./dist/adapters/redis.d.ts",
      "import": "./dist/adapters/redis.js",
      "default": "./dist/adapters/redis.js"
    },
    "./kv-cache": {
      "types": "./dist/kv-cache.d.ts",
      "import": "./dist/kv-cache.js",
      "default": "./dist/kv-cache.js"
    },
    "./kv": {
      "types": "./dist/kv.d.ts",
      "import": "./dist/kv.js",
      "default": "./dist/kv.js"
    },
    "./hash": {
      "types": "./dist/hash-index.d.ts",
      "import": "./dist/hash-index.js",
      "default": "./dist/hash-index.js"
    },
    "./set": {
      "types": "./dist/set-index.d.ts",
      "import": "./dist/set-index.js",
      "default": "./dist/set-index.js"
    },
    "./sorted-set": {
      "types": "./dist/sorted-set-index.d.ts",
      "import": "./dist/sorted-set-index.js",
      "default": "./dist/sorted-set-index.js"
    },
    "./list": {
      "types": "./dist/list-index.d.ts",
      "import": "./dist/list-index.js",
      "default": "./dist/list-index.js"
    },
    "./pubsub": {
      "types": "./dist/pubsub-index.d.ts",
      "import": "./dist/pubsub-index.js",
      "default": "./dist/pubsub-index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/adapters/bun.ts src/adapters/node.ts src/adapters/web.ts src/adapters/ioredis.ts src/adapters/redis.ts src/kv-cache.ts src/kv.ts src/hash-index.ts src/set-index.ts src/sorted-set-index.ts src/list-index.ts src/pubsub-index.ts --format esm --dts --clean --out-dir dist --external pg --external pg-boss --external @postgresx/bun-listen",
    "test": "bun test src",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.0.0",
    "@types/pg": "^8.16.0",
    "@postgresx/bun-listen": "workspace:*",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
